#go@ plink m1 -t ~/sdk/tests/test-all
#!/bin/bash
cd "${0%test-all}" || exit 1
file="$1"; shift

for f in $(cd ../lua; ls -1 *.lua); do
	[[ $file && $f != $file ]] && continue
	echo "$f"
	AUTO=1 ../bin/luajit -e"package.path=package.path..';$PWD/?.lua'" "../lua/$f" >test-stdout || break
	grep -q ok test-stdout || echo "NO-OK $f"
done

cleanup() {
	rm test-stdout
}
trap cleanup EXIT INT TERM
